# =============================================================================
# MARINE .gitignore
# =============================================================================

# --- 데이터셋: 대용량 + 재배포 금지(UIEB/EUVP 라이선스). README(취득 가이드)만 포함 ---
datasets/*
!datasets/README.md

# --- 학습 산출물(체크포인트/로그/샘플; 샘플엔 참조영상 포함되어 제외) ---
runs/

# --- 모델 가중치 ---
*.pth
*.pt
*.onnx

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# --- OS / 에디터 ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# --- 임시 ---
*.log
*.tmp
scratch/

# DUO 학습 config (prep_duo_yolo.py 가 생성; 머신별 절대경로)
configs/duo.yaml
